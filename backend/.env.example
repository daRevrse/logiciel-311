# ================================================
# CONFIGURATION ENVIRONNEMENT - Logiciel 311
# ================================================

# ----- SERVEUR -----
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000

# ----- BASE DE DONNÉES -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=logiciel_311
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql

# ----- SÉCURITÉ JWT -----
JWT_SECRET=votre_secret_jwt_tres_securise_a_changer_en_production
JWT_EXPIRES_IN=7d

# ----- LICENCE -----
# Clé master pour générer/valider les licences
LICENSE_MASTER_KEY=master_key_super_securisee_a_changer

# ----- UPLOAD FICHIERS -----
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
# 5MB en bytes (5 * 1024 * 1024)
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/webp

# ----- EMAIL (Nodemailer) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_app
EMAIL_FROM=noreply@logiciel311.tg

# ----- SMS (à configurer selon fournisseur Togo) -----
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=311TG

# ----- RATE LIMITING -----
RATE_LIMIT_WINDOW_MS=900000
# 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ----- LOGS -----
LOG_LEVEL=info
LOG_DIR=logs

# ----- FRONTEND URL (CORS) -----
FRONTEND_URL=http://localhost:5173
